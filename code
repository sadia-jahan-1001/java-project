EmptyBorder(25, 25, 25, 25))); 
        card.setMaximumSize(new Dimension(650, 300)); 
        card.setAlignmentX(Component.LEFT_ALIGNMENT); 
        String bold = "<html><b style='color:#64748b;'>"; 
        card.add(new JLabel(bold + "Name: </b>" + s.getName())); 
        card.add(new JLabel(bold + "ID: </b>" + s.getId())); 
        card.add(new JLabel(bold + "Department: </b>" + s.getDept())); 
        card.add(new JLabel(bold + "Subject: </b>" + s.getSubj())); 
        card.add(new JLabel(bold + "Admission Year: </b>" + s.getYear())); 
        card.add(new JLabel(bold + "Qualification: </b>" + s.getQual())); 
        card.add(new JLabel(bold + "Address: </b>" + s.getAddr())); 
        return card; 
    } 
 
