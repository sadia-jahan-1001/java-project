    private void setActiveButton(JButton active) { 
        if (activeNavButton != null) { activeNavButton.setBackground(BG_DARK); 
        activeNavButton.setForeground(TEXT_SECONDARY); } 
        activeNavButton = active; activeNavButton.setBackground(new Color(51, 65, 85)); 
activeNavButton.setForeground(Color.WHITE); 
    } 
 
    private JButton createNavButton(String text, ActionListener action) { 
        JButton btn = new JButton(text); 
        btn.setFont(NAV_FONT); btn.setForeground(TEXT_SECONDARY); 
btn.setBackground(BG_DARK); 
        btn.setBorderPainted(false); btn.setFocusPainted(false); 
btn.setHorizontalAlignment(SwingConstants.LEFT); 
        btn.setMaximumSize(new Dimension(220, 50)); btn.setCursor(new 
Cursor(Cursor.HAND_CURSOR)); 
        btn.setBorder(new EmptyBorder(10, 15, 10, 0)); 
        btn.addActionListener(e -> { setActiveButton(btn); action.actionPerformed(e); }); 
        return btn; 
    } 
     
    private JLabel createNavSectionLabel(String text) { 
        JLabel lbl = new JLabel(text); 
        lbl.setFont(new Font("Segoe UI", Font.BOLD, 11)); lbl.setForeground(new Color(100, 116, 
139)); return lbl; 
    } 
 
    private JPanel createSummaryCard(String title, String value, Color accentColor, String 
iconEmoji) { 
        JPanel card = new JPanel(new BorderLayout()); 
        card.setBackground(CARD_BG); card.setBorder(new LineBorder(new Color(226, 232, 
240), 1)); 
        JPanel content = new JPanel(); content.setLayout(new BoxLayout(content, 
BoxLayout.Y_AXIS)); content.setOpaque(false); 
        content.setBorder(new EmptyBorder(20, 25, 20, 25)); 
        content.add(new JLabel(iconEmoji) {{ setFont(new Font("Segoe UI Emoji", Font.PLAIN, 
24)); }}); 
        content.add(new JLabel(title) {{ setForeground(TEXT_SECONDARY); }}); 
        content.add(new JLabel(value) {{ setFont(new Font("Segoe UI", Font.BOLD, 28)); }}); 
        JPanel accentStrip = new JPanel(); accentStrip.setBackground(accentColor); 
accentStrip.setPreferredSize(new Dimension(0, 4)); 
        card.add(accentStrip, BorderLayout.NORTH); 
        card.add(content, BorderLayout.CENTER); return card; 
    } 
 
