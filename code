    private void showDatabase() { 
        headerTitle.setText("Student Directory"); 
        String[] cols = {"ID", "Name", "Department", "Year"}; 
        Object[][] data = new Object[studentList.size()][4]; 
        for(int i=0; i<studentList.size(); i++) { 
            Student s = studentList.get(i); 
            data[i] = new Object[]{s.getId(), s.getName(), s.getDept(), s.getYear()}; 
        } 
        JTable table = new JTable(new DefaultTableModel(data, cols)); 
        table.setRowHeight(35); 
        updateView(new JScrollPane(table)); 
    } 
 
