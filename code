    private void populateRandomStudents(int count) { 
        String[] firstNames = {"Abir", "Sadia", "Tanvir", "Nusrat", "Arif", "Fariha", "Kamal", "Laila", 
"Zahid", "Mitu"}; 
        String[] lastNames = {"Ahmed", "Hasan", "Khan", "Islam", "Rahman", "Jahan", "Akter", 
"Uddin", "Chowdhury", "Talukder"}; 
        String[] depts = {"CSE", "BBA", "EEE", "Economics", "English", "Textile", "Pharmacy"}; 
        String[] subjs = {"Software Engineering", "Finance", "Power Systems", "Microeconomics", 
"Literature", "Merchandising", "Clinical Pharmacy"}; 
        String[] quals = {"HSC", "A-Level", "Diploma"}; 
        String[] cities = {"Dhaka", "Chittagong", "Sylhet", "Rajshahi", "Khulna", "Barisal"}; 
 
        Random rand = new Random(); 
        for (int i = 0; i < count; i++) { 
            String name = firstNames[rand.nextInt(firstNames.length)] + " " + 
lastNames[rand.nextInt(lastNames.length)]; 
            String address = cities[rand.nextInt(cities.length)]; 
            int deptIdx = rand.nextInt(depts.length); 
            String dept = depts[deptIdx]; 
            String subj = subjs[deptIdx];  
            int year = 2020 + rand.nextInt(5); 
            String qual = quals[rand.nextInt(quals.length)]; 
             
            studentList.add(new Student(name, address, dept, subj, year, qual)); 
        } 
    } 
 
