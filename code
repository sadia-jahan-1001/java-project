    private void showSearch() { 
        headerTitle.setText("Search Student"); 
        JPanel wrapper = new JPanel(new BorderLayout()); 
        wrapper.setOpaque(false); 
 
        JPanel searchBarPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0)); 
        searchBarPanel.setOpaque(false); 
        JTextField searchField = new JTextField(20); 
        searchField.setPreferredSize(new Dimension(300, 45)); 
        searchField.setFont(MAIN_FONT); 
        searchField.setBorder(BorderFactory.createCompoundBorder(new LineBorder(new 
Color(203, 213, 225), 1), new EmptyBorder(5, 15, 5, 15))); 
 
        JButton btnGo = new JButton("Search ID"); 
        btnGo.setPreferredSize(new Dimension(120, 45)); 
        btnGo.setBackground(Color.BLACK); 
        btnGo.setForeground(Color.WHITE); 
        btnGo.setFont(new Font("Segoe UI", Font.BOLD, 14)); 
        btnGo.setFocusPainted(false); 
        btnGo.setBorderPainted(false); 
        btnGo.setCursor(new Cursor(Cursor.HAND_CURSOR)); 
 
        searchBarPanel.add(searchField); 
        searchBarPanel.add(Box.createHorizontalStrut(10)); 
        searchBarPanel.add(btnGo); 
 
        JPanel resultArea = new JPanel(); 
        resultArea.setLayout(new BoxLayout(resultArea, BoxLayout.Y_AXIS)); 
        resultArea.setOpaque(false); 
        resultArea.setBorder(new EmptyBorder(30, 0, 0, 0)); 
 
        ActionListener performSearch = e -> { 
            resultArea.removeAll(); 
            String input = searchField.getText().trim(); 
            if (input.isEmpty()) { JOptionPane.showMessageDialog(this, "Please enter an ID."); 
return; } 
            try { 
                int id = Integer.parseInt(input); 
                Student found = null; 
                for (Student s : studentList) { 
                    if (s.getId() == id) { found = s; break; } 
                } 
                if (found != null) { 
                    resultArea.add(createStudentProfileCard(found)); 
                } else { 
                    JLabel notFound = new JLabel("No student found with ID: " + id); 
                    notFound.setFont(MAIN_FONT); notFound.setForeground(Color.RED); 
                    resultArea.add(notFound); 
                } 
            } catch (NumberFormatException ex) { JOptionPane.showMessageDialog(this, "ID must 
be a number."); } 
            resultArea.revalidate(); resultArea.repaint(); 
        }; 
 
        btnGo.addActionListener(performSearch); 
        wrapper.add(searchBarPanel, BorderLayout.NORTH); 
        wrapper.add(resultArea, BorderLayout.CENTER); 
        updateView(wrapper); 
    } 
 
    void admissionFlow() { 
        UIManager.put("OptionPane.background", CARD_BG); 
        UIManager.put("Panel.background", CARD_BG); 
 
        String[] schools = {"School of Engineering (SE)", "School of Arts & Social Sciences 
(SASS)", "School of Business Studies (SBS)"}; 
        String selectedSchool = (String) JOptionPane.showInputDialog(this, "Select Faculty:", 
"Step 1: Faculty Selection", JOptionPane.PLAIN_MESSAGE, null, schools, schools[0]); 
        if (selectedSchool == null) return; 
 
        String[] depts; 
        if (selectedSchool.contains("(SE)")) depts = new String[]{"CSE", "EEE", "Textile 
Engineering", "Architecture"}; 
        else if (selectedSchool.contains("(SASS)")) depts = new String[]{"Economics", "English", 
"Bangla"}; 
        else depts = new String[]{"Business Administration"}; 
 
        String selectedDept = (String) JOptionPane.showInputDialog(this, "Select Department:", 
"Step 2: Department Selection", JOptionPane.PLAIN_MESSAGE, null, depts, depts[0]); 
        if (selectedDept == null) return; 
 
        JTextField nameF = new JTextField(); 
        JTextField addrF = new JTextField(); 
        JTextField yearF = new JTextField(); JTextField qualF = new JTextField(); JTextField subjF 
= new JTextField(); 
        Object[] form = {"Full Name:", nameF, "Address:", addrF, "Year:", yearF, "Qualification:", 
qualF, "Subject:", subjF}; 
        int result = JOptionPane.showConfirmDialog(this, form, "Step 3: Personal Information", 
JOptionPane.OK_CANCEL_OPTION, JOptionPane.PLAIN_MESSAGE); 
        if (result == JOptionPane.OK_OPTION) { 
            try { 
                Student s = new Student(nameF.getText(), addrF.getText(), selectedDept, 
subjF.getText(), Integer.parseInt(yearF.getText()), qualF.getText()); 
                studentList.add(s); 
                JOptionPane.showMessageDialog(this, "Student Admitted Successfully!\nAssigned 
ID: " + s.getId()); 
            } catch (HeadlessException | NumberFormatException e) { 
JOptionPane.showMessageDialog(this, "Validation Failed: Ensure Year is numeric."); } 
        } 
    } 
 
