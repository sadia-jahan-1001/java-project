abstract class Person { 
    protected String name, address; 
    Person(String name, String address) {  
        this.name = name;  
        this.address = address; 
    } 
    public abstract String getName(); 
    public abstract String getAddr(); 
} 
 
class Student extends Person { 
    private static int counter = 20261000; 
    private final int id; 
    private int year; 
    private String department, subject, qualification; 
 
    Student(String n, String a, String d, String s, int y, String q) { 
        super(n, a); 
        this.id = ++counter; 
        this.department = d; 
        this.subject = s; this.year = y; this.qualification = q; 
    } 
 
    public int getId() { return id; } 
     
    @Override 
    public String getName() { return name; } 
     
    @Override 
    public String getAddr() { return address; } 
     
    public String getDept() { return department; } 
    public String getSubj() { return subject; } 
    public int getYear() { return year; } 
    public String getQual() { return qualification; } 
} 
